# Supabase — project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key: server-only, bypasses RLS. Used by admin actions,
# guest-account creation, and the AI Analyst writer. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gates /admin (plaintext compare — fine for a demo, rotate if shared)
ADMIN_PASSWORD=choose-a-strong-password

# AI Analyst provider — set ONE of these. Vultr wins if both are set.
# Vultr Serverless Inference (OpenAI-compatible, free tier)
VULTR_API_KEY=
VULTR_BASE_URL=https://api.vultrinference.com/v1/
VULTR_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# Protects the cron endpoint. Vercel sends it automatically as a Bearer token
# when set in the project's environment variables.
CRON_SECRET=any-long-random-string
